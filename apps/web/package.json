{
  "name": "@sir/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "test": "jest --passWithNoTests --coverage",
    "lint": "next lint",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.35.0",
    "@react-email/components": "^0.0.33",
    "@sir/ai": "workspace:*",
    "@sir/analytics": "workspace:^",
    "@sir/db": "workspace:*",
    "@sir/shared": "workspace:*",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.47.0",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.35.0",
    "next": "14.2.18",
    "posthog-js": "^1.373.5",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "reactflow": "^11.11.4",
    "resend": "^4.0.0",
    "stripe": "^17.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@sir/ai$": "<rootDir>/../../packages/ai/src/index.ts",
      "^@sir/db$": "<rootDir>/../../packages/db/src/index.ts",
      "^@sir/shared$": "<rootDir>/../../packages/shared/src/index.ts",
      "^@sir/analytics$": "<rootDir>/../../packages/analytics/src/index.ts",
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "coverageThreshold": {
      "global": {
        "lines": 80
      }
    }
  }
}
