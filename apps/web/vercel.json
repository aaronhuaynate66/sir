{
  "framework": "nextjs",
  "installCommand": "npm install -g pnpm@9.0.0 && cd ../.. && pnpm install --no-frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm turbo build --filter=@sir/web...",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/notifications/engine",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/neo4j/sync",
      "schedule": "0 2 * * *"
    }
  ]
}
